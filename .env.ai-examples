# ========================================
# AI/ML PROVIDER CONFIGURATIONS
# ========================================

# OpenAI Configuration (Default)
AI_PROVIDER=openai
AI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude Configuration
# AI_PROVIDER=anthropic
# AI_API_KEY=your-anthropic-api-key
# AI_MODEL=claude-3-haiku-20240307
# AI_BASE_URL=https://api.anthropic.com

# Ollama (Local LLM) Configuration
# AI_PROVIDER=ollama
# AI_API_KEY=dummy-key
# AI_MODEL=llama3.1:8b
# AI_BASE_URL=http://localhost:11434/v1

# Custom API Configuration
# AI_PROVIDER=custom
# AI_API_KEY=your-custom-api-key
# AI_MODEL=your-custom-model-name
# AI_BASE_URL=https://your-custom-api.com/v1

# ========================================
# EXAMPLES FOR DIFFERENT SCENARIOS
# ========================================

# For Google Gemini (via OpenAI-compatible endpoint):
# AI_PROVIDER=custom
# AI_API_KEY=your-gemini-key
# AI_MODEL=gemini-1.5-flash
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# For Mistral AI:
# AI_PROVIDER=custom
# AI_API_KEY=your-mistral-key
# AI_MODEL=mistral-large-latest
# AI_BASE_URL=https://api.mistral.ai/v1

# For Groq:
# AI_PROVIDER=custom
# AI_API_KEY=your-groq-key
# AI_MODEL=llama3-70b-8192
# AI_BASE_URL=https://api.groq.com/openai/v1

# ========================================
# NOTES
# ========================================
# 1. AI_PROVIDER determines which client logic to use
# 2. AI_MODEL must be compatible with the chosen provider
# 3. AI_BASE_URL should point to the provider's API endpoint
# 4. For local models (Ollama), use dummy API key
# 5. The system falls back to deterministic validation if AI fails