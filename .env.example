# Database
DATABASE_URL=postgresql://user:password@localhost:5432/email_processor
REDIS_URL=redis://localhost:6379/0

# Email
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-service@gmail.com
IMAP_PASSWORD=your-app-password

# SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-service@gmail.com
SMTP_PASSWORD=your-app-password

# AI/ML Validation (OpenAI-compatible API)
AI_API_KEY=your-ai-api-key
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# Альтернативные провайдеры (любой OpenAI-совместимый API):
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_BASE_URL=https://neuroapi.host/v1
# AI_BASE_URL=http://localhost:11434/v1  # Ollama локально

# Примеры моделей:
# AI_MODEL=gpt-4o-mini
# AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
# AI_MODEL=mistralai/mistral-7b-instruct:free

# Security
SECRET_KEY=your-secret-key-for-jwt

# Storage
UPLOAD_DIR=./uploads
MAX_PDF_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json